{
	"info": {
		"name": "MiInbox API - Facturify",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Login (Obtener JWT)",
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Content-Type", "value": "application/json" },
					{ "key": "Accept", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"admin@facturify.com\",\n    \"password\": \"password123\"\n}"
				},
				"url": { "raw": "http://127.0.0.1:8000/api/login", "protocol": "http", "host": ["127", "0", "0", "1"], "port": "8000", "path": ["api", "login"] }
			}
		},
		{
			"name": "2. Listar Hilos (Threads)",
			"request": {
				"method": "GET",
				"header": [
					{ "key": "Accept", "value": "application/json" },
					{ "key": "Authorization", "value": "Bearer {{token_jwt_aqui}}" }
				],
				"url": { "raw": "http://127.0.0.1:8000/api/threads", "protocol": "http", "host": ["127", "0", "0", "1"], "port": "8000", "path": ["api", "threads"] }
			}
		},
		{
			"name": "3. Ver un Hilo Específico",
			"request": {
				"method": "GET",
				"header": [
					{ "key": "Accept", "value": "application/json" },
					{ "key": "Authorization", "value": "Bearer {{token_jwt_aqui}}" }
				],
				"url": { "raw": "http://127.0.0.1:8000/api/threads/1", "protocol": "http", "host": ["127", "0", "0", "1"], "port": "8000", "path": ["api", "threads", "1"] }
			}
		},
		{
			"name": "4. Responder en un Hilo",
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Content-Type", "value": "application/json" },
					{ "key": "Accept", "value": "application/json" },
					{ "key": "Authorization", "value": "Bearer {{token_jwt_aqui}}" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"body\": \"Respuesta de prueba enviada desde Postman.\"\n}"
				},
				"url": { "raw": "http://127.0.0.1:8000/api/threads/1/messages", "protocol": "http", "host": ["127", "0", "0", "1"], "port": "8000", "path": ["api", "threads", "1", "messages"] }
			}
		}
	]
}